# Database (local development defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=copilotkit

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Frontend / backend runtime
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PORT=3500

# AI gateway (required for copilot actions)
BIFROST_BASE_URL=http://localhost:8080/v1
BIFROST_API_KEY=
BIFROST_MODEL=groq/llama-3.3-70b-versatile
COPILOT_CLOUD_API_KEY=

# Optional tracing
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Log toggles
ENABLE_DEBUG_LOGS=true
