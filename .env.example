# ============================================
# 🗄️ DATABASE (auto-configured by Docker)
# ============================================
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=copilotkit

# ============================================
# 🔐 AUTHENTICATION (auto-generated by setup)
# ============================================
JWT_SECRET=CHANGE_ME_GENERATED_BY_SETUP

# ============================================
# 🧠 AI GATEWAY — BIFROST (auto-configured)
# ============================================
BIFROST_BASE_URL=http://bifrost:8080/v1
BIFROST_API_KEY=CHANGE_ME_GENERATED_BY_SETUP
BIFROST_MODEL=groq/llama-3.3-70b-versatile
COPILOT_CLOUD_API_KEY=

# ============================================
# 📊 LANGFUSE TRACING (optional)
# ============================================
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================
# 🌐 NETWORKING (defaults work for Docker)
# ============================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3500
NODE_ENV=production
PORT=3500

# ============================================
# 🔑 OAUTH (optional — leave blank to skip)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ============================================
# 📦 AWS S3 (optional — leave blank to skip)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ============================================
# 🪵 DEBUG (disabled in production)
# ============================================
ENABLE_DEBUG_LOGS=false
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false
